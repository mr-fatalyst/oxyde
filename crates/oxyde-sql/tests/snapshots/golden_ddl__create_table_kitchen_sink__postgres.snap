CREATE TABLE "kitchen_sink" ( "col_int" INTEGER NOT NULL, "col_str" VARCHAR(255) NOT NULL, "col_str_100" VARCHAR(100) NOT NULL, "col_float" DOUBLE PRECISION NOT NULL, "col_bool" BOOLEAN NOT NULL, "col_bytes" BYTEA NOT NULL, "col_datetime" TIMESTAMP NOT NULL, "col_date" DATE NOT NULL, "col_time" TIME NOT NULL, "col_timedelta" BIGINT NOT NULL, "col_uuid" UUID NOT NULL, "col_decimal" NUMERIC NOT NULL, "col_decimal_10_2" NUMERIC(10,2) NOT NULL, "col_json" JSONB NOT NULL, "col_unknown" TEXT NOT NULL, "arr_int" INTEGER[] NOT NULL, "arr_str" VARCHAR(255)[] NOT NULL, "arr_uuid" UUID[] NOT NULL, "arr_decimal" NUMERIC[] NOT NULL, "col_nullable" VARCHAR(255), "col_unique" VARCHAR(255) NOT NULL UNIQUE, "def_str" VARCHAR(255) NOT NULL DEFAULT 'hello', "def_int" INTEGER NOT NULL DEFAULT 42, "def_float" DOUBLE PRECISION NOT NULL DEFAULT 1.5, "def_bool" BOOLEAN NOT NULL DEFAULT TRUE, "def_now" TIMESTAMP NOT NULL DEFAULT CURRENT_TIMESTAMP )
