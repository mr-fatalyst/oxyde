---
source: crates/oxyde-migrate/tests/golden_ddl.rs
expression: sql
---
CREATE TABLE "post" ( "id" INTEGER PRIMARY KEY AUTOINCREMENT, "title" VARCHAR(255) NOT NULL, "author_id" INTEGER NOT NULL, "editor_id" INTEGER, "reviewer_id" INTEGER, "owner_id" INTEGER, FOREIGN KEY ("author_id") REFERENCES "author" ("id") ON DELETE CASCADE ON UPDATE CASCADE, FOREIGN KEY ("editor_id") REFERENCES "author" ("id") ON DELETE SET NULL ON UPDATE NO ACTION, FOREIGN KEY ("reviewer_id") REFERENCES "author" ("id") ON DELETE RESTRICT ON UPDATE SET DEFAULT, FOREIGN KEY ("owner_id") REFERENCES "author" ("id") ON DELETE NO ACTION ON UPDATE NO ACTION, CHECK (LENGTH(title) > 0) );

CREATE INDEX "ix_post_title" ON "post" ("title")
